prefix=/home/zzx/FFmpeg-release-7.1/ffmpeg_install
exec_prefix=${prefix}
libdir=/home/zzx/FFmpeg-release-7.1/ffmpeg_install/lib
includedir=/home/zzx/FFmpeg-release-7.1/ffmpeg_install/include

Name: libavfilter
Description: FFmpeg audio/video filtering library
Version: 10.5.100
Requires: 
Requires.private: libswscale >= 8.3.100, libpostproc >= 58.3.100, libavformat >= 61.7.100, libavcodec >= 61.19.101, libswresample >= 5.3.100, libavutil >= 59.39.100
Conflicts:
Libs: -L${libdir}  -lavfilter 
Libs.private: -lm -latomic -lnppig -lnppicc -lnppc -lnppidei -lnppif
Cflags: -I${includedir}

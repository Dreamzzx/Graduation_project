prefix=/home/zzx/FFmpeg-release-7.1/ffmpeg_install
exec_prefix=${prefix}
libdir=/home/zzx/FFmpeg-release-7.1/ffmpeg_install/lib
includedir=/home/zzx/FFmpeg-release-7.1/ffmpeg_install/include

Name: libavdevice
Description: FFmpeg device handling library
Version: 61.3.100
Requires: 
Requires.private: libavfilter >= 10.5.100, libswscale >= 8.3.100, libpostproc >= 58.3.100, libavformat >= 61.7.100, libavcodec >= 61.19.101, libswresample >= 5.3.100, libavutil >= 59.39.100
Conflicts:
Libs: -L${libdir}  -lavdevice 
Libs.private: -lpsapi -lole32 -lstrmiids -luuid -loleaut32 -lshlwapi -lgdi32 -lm -latomic -lvfw32
Cflags: -I${includedir}

{
    "name": "东北角",
    "enabled": true,
    "capture": {
        "device_name": "video=HP Wide Vision HD Camera",
        "input_format": "dshow",
        "video_width": 1280,
        "video_height": 720,
        "framerate": 30
    },
    "push": {
        "rtsp_url": "rtsp://localhost:8554/live/t2",
        "video_width": 1920,
        "video_height": 1080,
        "frame_rate": 24,
        "video_bitrate": 5000000
    },
    "detector": {
        "enabled": true,
        "model_path": "model/yolo11n.onnx",
        "confidence_threshold": 0.5,
        "input_width": 640,
        "input_height": 640,
        "classes": [
            "person"
        ]
    },
    "recorder": {
        "enabled": false,
        "output_dir": "recordings",
        "person_leave_timeout_ms": 3000
    },
    "log": {
        "level": "info",
        "debug_enabled": false
    }
}
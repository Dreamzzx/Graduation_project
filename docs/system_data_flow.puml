@startuml system_sequence
title 完整系统时序图

actor 用户
participant Web界面
participant Flask API
participant ZPusher
participant VideoSource
participant Detector
participant FFmpegPush
participant VideoRecorder
participant MediaMTX

用户 -> Web界面 : 配置流参数
Web界面 -> Flask API : POST /api/streams
Flask API -> ZPusher : Init(config_path)
ZPusher -> VideoSource : 初始化视频源
ZPusher -> Detector : 初始化检测器
ZPusher -> FFmpegPush : 初始化推流器
ZPusher -> VideoRecorder : 初始化录制器

用户 -> Web界面 : 启动流
Web界面 -> Flask API : POST /api/streams/{id}/start
Flask API -> ZPusher : start_Push()

loop 视频处理循环
    VideoSource -> VideoSource : 采集帧
    VideoSource -> Detector : Push到capture_queue
    Detector -> Detector : 推理检测
    Detector -> FFmpegPush : Push到detect_queue
    FFmpegPush -> FFmpegPush : 编码帧
    FFmpegPush -> MediaMTX : RTSP推流
    MediaMTX -> Web界面 : HLS播放
    
    alt 检测到目标
        Detector -> VideoRecorder : has_person=true
        VideoRecorder -> VideoRecorder : 开始录制
    else 未检测到目标
        Detector -> VideoRecorder : has_person=false
        VideoRecorder -> VideoRecorder : 停止录制
    end
end

@enduml

@startuml data_structure_er
title 数据结构关系图

entity "FRAME_DATA" as FD {
    cv::Mat frame
    --
    vector<Detection> detections
    int64_t timestamp_ms
    int64_t frame_id
    bool has_person
}

entity "DETECTION" as DET {
    cv::Rect bbox
    --
    float confidence
    int class_id
    string class_name
}

entity "CAPTURE_CONFIG" as CC {
    string device_name
    --
    int video_width
    int video_height
    int framerate
}

entity "PUSH_CONFIG" as PC {
    string rtsp_url
    --
    int video_width
    int video_height
    int video_bitrate
    int frame_rate
}

entity "DETECTOR_CONFIG" as DC {
    bool enabled
    --
    string model_path
    vector<string> classes
    float confidence_threshold
    int input_width
}

entity "RECORDER_CONFIG" as RC {
    bool enabled
    --
    string output_dir
    int person_leave_timeout_ms
}

FD ||--o{ DET : contains
CC ||--|| VideoSource : configures
PC ||--|| FFmpegPush : configures
DC ||--|| YOLOv11Detector : configures
RC ||--|| VideoRecorder : configures

@enduml

